<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AppStore" parent="Theme.SplashScreen">
        <!-- No icon: just the app background. Cleaner launch transition. -->
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.AppStore.Main</item>
    </style>

    <style name="Theme.AppStore.Main" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
