<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base theme used briefly before Compose takes over. Edge-to-edge,
         splash-screen colours sourced from the launcher icon palette so the
         transition into the in-app theme is seamless. -->
    <style name="Theme.GroomHub" parent="Theme.SplashScreen">
        <!-- No icon: just the app background. Cleaner launch transition. -->
        <item name="windowSplashScreenBackground">@color/splash_background</item>
        <item name="postSplashScreenTheme">@style/Theme.GroomHub.Main</item>
    </style>

    <style name="Theme.GroomHub.Main" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
